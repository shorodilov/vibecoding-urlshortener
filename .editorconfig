# EditorConfig
# see: https://editorconfig.org

root = true

# Common settings
[*]
charset = utf-8
tab_width = 4
indent_size = 4
indent_style = space
max_line_length = 119
# Unix-style newlines with a newline ending every file
end_of_line = lf
insert_final_newline = true

[*.{json,xml,yaml,yml}]
indent_size = 2
tab_width = 2
